DirectoryIndex index.php

<IfModule mod_rewrite.c>
    Options +FollowSymLinks -MultiViews -Indexes
    RewriteEngine On

    # Serve compiled Vite assets, favicon, and other public/ files.
    RewriteRule ^(build/.+|favicon\.svg|robots\.txt|storage/.+)$ public/$1 [L]

    # Laravel front controller (root index.php sets correct base path for subfolders).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_authz_core.c>
    <Files "index.php">
        Require all granted
    </Files>
</IfModule>

<IfModule !mod_authz_core.c>
    <Files "index.php">
        Order allow,deny
        Allow from all
    </Files>
</IfModule>
